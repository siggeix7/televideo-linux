def request_bytes(url: str, timeout: float) -> bytes:
    request = urllib.request.Request(url, headers={"User-Agent": USER_AGENT})
    try:
        with urllib.request.urlopen(request, timeout=timeout) as response:
            return response.read()
    except urllib.error.HTTPError as exc:
        raise RuntimeError(f"HTTP {exc.code} da {url}") from exc
    except urllib.error.URLError as exc:
        raise RuntimeError(f"impossibile raggiungere {url}: {exc.reason}") from exc
    except TimeoutError as exc:
        raise RuntimeError(f"timeout durante il collegamento a {url}") from exc


def fetch_bytes(urls: list[str], timeout: float, retries: int) -> tuple[bytes, str]:
    errors = []
    for _ in range(retries + 1):
        for url in urls:
            try:
                return request_bytes(url, timeout), url
            except RuntimeError as exc:
                errors.append(str(exc))
    last_error = errors[-1] if errors else "nessun URL configurato"
    raise RuntimeError(f"nessuna risposta valida dagli host Rai. Ultimo errore: {last_error}")


def fetch_text(urls: list[str], timeout: float, retries: int) -> tuple[str, str]:
    data, url = fetch_bytes(urls, timeout, retries)
    return data.decode("utf-8", errors="replace"), url


def fetch_json(url: str, timeout: float, retries: int) -> dict:
    source, _ = fetch_text([url], timeout, retries)
    try:
        payload = json.loads(source)
    except json.JSONDecodeError as exc:
        raise RuntimeError("risposta JSON del traduttore non riconosciuta") from exc
    if not isinstance(payload, dict):
        raise RuntimeError("risposta JSON del traduttore inattesa")
    return payload


def strip_html(value: str) -> str:
    value = re.sub(r"<br\s*/?>", "\n", value, flags=re.IGNORECASE)
    value = re.sub(r"<[^>]+>", "", value)
    return html.unescape(value)


def compact_text(value: str) -> str:
    return re.sub(r"\s+", " ", strip_html(value)).strip()


def normalize_lookup(value: str) -> str:
    normalized = unicodedata.normalize("NFKD", value.casefold())
    normalized = "".join(char for char in normalized if not unicodedata.combining(char))
    return re.sub(r"[^a-z0-9]+", " ", normalized).strip()


def extract_page(html_text: str) -> tuple[str, str]:
    header_match = re.search(r"Pagina\s+(\d{1,3})\s+-\s+sottopagina\s+([0-9A-Za-z]+)", html_text)
    pre_match = re.search(r"<pre\b[^>]*>(.*?)</pre>", html_text, flags=re.IGNORECASE | re.DOTALL)
    if not header_match or not pre_match:
        raise RuntimeError("formato della pagina Rai non riconosciuto")

    header = f"Pagina {header_match.group(1).zfill(3)} - sottopagina {header_match.group(2)}"
    content = strip_html(pre_match.group(1)).replace("\r\n", "\n").replace("\r", "\n").replace("\t", "")
    lines = [line.rstrip() for line in content.splitlines()]

    while lines and not lines[0].strip():
        lines.pop(0)
    while lines and not lines[-1].strip():
        lines.pop()

    return header, "\n".join(lines)


def format_text_page(page: str, subpage: str | None, region: str, show_url: bool, timeout: float, retries: int) -> str:
    source, url = fetch_text(build_text_urls(page, subpage, region), timeout, retries)
    header, content = extract_page(source)
    lines = []

    if region:
        lines.append(f"Rai Televideo regionale: {region}")
    else:
        lines.append("Rai Televideo nazionale")
    lines.append(header)
    if show_url:
        lines.append(url)
    lines.append("")
    lines.append(content or "Pagina vuota o non disponibile.")
    return "\n".join(lines)


def extract_capture(html_text: str) -> str:
    pre_match = re.search(r"<pre\b[^>]*>(.*?)</pre>", html_text, flags=re.IGNORECASE | re.DOTALL)
    if not pre_match:
        raise RuntimeError("formato cattura sottopagine Rai non riconosciuto")

    content = strip_html(pre_match.group(1)).replace("\r\n", "\n").replace("\r", "\n").replace("\t", "")
    lines = [line.rstrip() for line in content.splitlines()]
    cleaned = []
    previous_blank = False
    for line in lines:
        if not line.strip():
            if not previous_blank:
                cleaned.append("")
            previous_blank = True
            continue
        cleaned.append(line)
        previous_blank = False

    while cleaned and not cleaned[0].strip():
        cleaned.pop(0)
    while cleaned and not cleaned[-1].strip():
        cleaned.pop()

    return "\n".join(cleaned)


def format_capture_page(page: str, region: str, show_url: bool, timeout: float, retries: int) -> str:
    source, url = fetch_text(build_capture_urls(page, region), timeout, retries)
    lines = []
    if region:
        lines.append(f"Rai Televideo regionale: {region}")
    else:
        lines.append("Rai Televideo nazionale")
    lines.append(f"Cattura sottopagine pagina {page}")
    if show_url:
        lines.append(url)
    lines.append("")
    lines.append(extract_capture(source) or "Cattura sottopagine non disponibile per questa pagina.")
    return "\n".join(lines)


def parse_news_feed(rss_text: str) -> tuple[list[dict[str, str]], dict[str, str]]:
    try:
        root = ET.fromstring(rss_text)
    except ET.ParseError as exc:
        raise RuntimeError("formato RSS Rai non riconosciuto") from exc

    channel = root.find("./channel")
    if channel is None:
        raise RuntimeError("canale RSS Rai non riconosciuto")

    metadata = {
        "title": compact_text(channel.findtext("title") or ""),
        "description": compact_text(channel.findtext("description") or ""),
        "pub_date": compact_text(channel.findtext("pubDate") or ""),
        "last_build_date": compact_text(channel.findtext("lastBuildDate") or ""),
    }
    items = []
    for item in channel.findall("item"):
        title = compact_text(item.findtext("title") or "")
        description = compact_text(item.findtext("description") or "")
        pub_date = compact_text(item.findtext("pubDate") or "")
        link = compact_text(item.findtext("link") or "")
        if title:
            items.append({"title": title, "description": description, "pub_date": pub_date, "link": link})
    return items, metadata


def format_news(limit: int, full: bool, search: str | None, show_url: bool, timeout: float, retries: int) -> str:
    source, url = fetch_text(build_rss_urls(), timeout, retries)
    items, metadata = parse_news_feed(source)
    if search:
        needle = search.casefold()
        items = [item for item in items if needle in (item["title"] + " " + item["description"]).casefold()]

    items = items[:limit]
    heading = "Ultim'Ora Televideo"
    if search:
        heading += f" - ricerca: {search}"

    lines = [heading]
    if metadata.get("pub_date") or metadata.get("last_build_date"):
        lines.append("Aggiornamento Rai: " + (metadata.get("pub_date") or metadata.get("last_build_date") or ""))
    if show_url:
        lines.append(url)
    lines.append("")

    if not items:
        lines.append("Nessuna notizia trovata.")
        return "\n".join(lines)

    for index, item in enumerate(items, start=1):
        date = item["pub_date"]
        prefix = f"{index:2d}. "
        lines.append(prefix + item["title"])
        if date:
            lines.append("    " + date)
        if show_url and item["link"]:
            lines.append("    " + item["link"])
        if full and item["description"]:
            wrapped = textwrap.wrap(item["description"], width=76)
            lines.extend("    " + line for line in wrapped)
        lines.append("")

    return "\n".join(lines).rstrip()


def mymemory_translate_to_latin(text: str, timeout: float, retries: int) -> str:
    query = {
        "q": text,
        "langpair": "it|la",
    }
    email = os.environ.get("TELEVIDEO_MYMEMORY_EMAIL")
    if email:
        query["de"] = email
    url = MYMEMORY_URL + "?" + urllib.parse.urlencode(query)
    payload = fetch_json(url, timeout, retries)

    response = payload.get("responseData")
    if not isinstance(response, dict):
        raise RuntimeError("traduttore MyMemory senza responseData")

    translated = compact_text(str(response.get("translatedText") or ""))
    status = payload.get("responseStatus")
    if status and int(status) >= 400:
        detail = payload.get("responseDetails") or "errore sconosciuto"
        raise RuntimeError(f"traduttore MyMemory: {detail}")
    if not translated:
        raise RuntimeError("traduttore MyMemory senza testo tradotto")
    return translated


def google_translate_to_latin(text: str, timeout: float, retries: int) -> str:
    query = {
        "client": "gtx",
        "sl": "it",
        "tl": "la",
        "dt": "t",
        "q": text,
    }
    url = GOOGLE_TRANSLATE_URL + "?" + urllib.parse.urlencode(query)
    source, _ = fetch_text([url], timeout, retries)
    try:
        payload = json.loads(source)
    except json.JSONDecodeError as exc:
        raise RuntimeError("risposta JSON di Google Translate non riconosciuta") from exc

    if not isinstance(payload, list) or not payload or not isinstance(payload[0], list):
        raise RuntimeError("risposta Google Translate inattesa")

    parts = []
    for segment in payload[0]:
        if isinstance(segment, list) and segment and isinstance(segment[0], str):
            parts.append(segment[0])
    translated = compact_text("".join(parts))
    if not translated:
        raise RuntimeError("Google Translate senza testo tradotto")
    return translated


def medieval_latin_style(text: str) -> str:
    text = compact_text(text)
    substitutions = (
        (r"\bPapa\b", "dominus Papa"),
        (r"\bPontifex\b", "summus Pontifex"),
        (r"\bminister\b", "dominus minister"),
        (r"\bItalia\b", "regnum Italiae"),
        (r"\bCivitat(?:es|ibus) Foederat(?:ae|is)\b", "terrae Americanae"),
        (r"\bhodie\b", "hoc die"),
        (r"\bnuntiat\b", "in chronicis nuntiat"),
    )
    for pattern, replacement in substitutions:
        text = re.sub(pattern, replacement, text, flags=re.IGNORECASE)

    # Grafia frequente nei testi medioevali: ae/oe spesso semplificati in e.
    text = re.sub("ae", "e", text, flags=re.IGNORECASE)
    text = re.sub("oe", "e", text, flags=re.IGNORECASE)
    return text


def translate_latin_or_fallback(text: str, translator: str, timeout: float, retries: int, cache: dict[str, str], allow_local: bool = True) -> str:
    key = f"{translator}\0{text}"
    if key in cache:
        return cache[key]

    providers = [translator]
    if translator == "auto":
        providers = ["google", "mymemory"]
        if allow_local:
            providers.append("local")
    elif allow_local and translator in {"google", "mymemory"}:
        providers.append("local")

    errors = []
    translated = ""
    for provider in providers:
        try:
            if provider == "google":
                translated = google_translate_to_latin(text, timeout, retries)
            elif provider == "mymemory":
                translated = mymemory_translate_to_latin(text, timeout, retries)
            elif provider == "local" and allow_local:
                translated = latinize_title(text)
            else:
                raise RuntimeError(f"traduttore latino non supportato: {provider}")
            break
        except RuntimeError as exc:
            errors.append(str(exc))

    if not translated:
        raise RuntimeError("traduzione latina non disponibile: " + "; ".join(errors))

    translated = medieval_latin_style(translated)
    cache[key] = translated
    return translated


def roman_number(number: int) -> str:
    values = (
        (1000, "M"),
        (900, "CM"),
        (500, "D"),
        (400, "CD"),
        (100, "C"),
        (90, "XC"),
        (50, "L"),
        (40, "XL"),
        (10, "X"),
        (9, "IX"),
        (5, "V"),
        (4, "IV"),
        (1, "I"),
    )
    result = []
    for value, numeral in values:
        while number >= value:
            result.append(numeral)
            number -= value
    return "".join(result)


def latinize_title(title: str) -> str:
    normalized_title = normalize_lookup(title)
    if normalized_title in LATIN_TITLE_OVERRIDES:
        return LATIN_TITLE_OVERRIDES[normalized_title]

    tokens = re.findall(r"[\w']+|[^\w\s]", title, flags=re.UNICODE)
    translated = []
    for token in tokens:
        if re.fullmatch(r"[^\w\s]", token, flags=re.UNICODE):
            translated.append(token)
            continue
        if token.isdigit() or re.fullmatch(r"[IVXLCDM]+", token):
            translated.append(token)
            continue

        lookup = normalize_lookup(token)
        latin = LATIN_WORDS.get(lookup)
        if latin is None:
            latin = token if token[:1].isupper() else token
        if latin:
            translated.append(latin)

    return join_title_tokens(translated) or "Nuntium sine titulo"


def preserve_title_lead(source_title: str, latin_title: str) -> str:
    if ":" not in source_title or ":" not in latin_title:
        return latin_title
    source_lead = source_title.split(":", 1)[0].strip()
    if not re.fullmatch(r"[A-Z][\w'.-]{1,24}", source_lead, flags=re.UNICODE):
        return latin_title
    return source_lead + ":" + latin_title.split(":", 1)[1]


def translate_latin_title(title: str, translator: str, timeout: float, retries: int, cache: dict[str, str]) -> str:
    latin_title = translate_latin_or_fallback(title, translator, timeout, retries, cache)
    return preserve_title_lead(title, latin_title)


def join_title_tokens(tokens: list[str]) -> str:
    output = []
    for token in tokens:
        if token in {",", ".", ":", ";", "!", "?"} and output:
            output[-1] += token
        else:
            output.append(token)
    return " ".join(output)


def summarize_description(description: str) -> str:
    text = re.sub(r"^\d{1,2}\.\d{2}\s+", "", description).strip()
    sentences = [part.strip() for part in re.split(r"(?<=[.!?])\s+|(?<=[.!?])(?=[A-Z])", text) if part.strip()]
    selected = []
    for sentence in sentences[:SUMMARY_SENTENCES]:
        candidate = " ".join(selected + [sentence])
        if len(candidate) <= SUMMARY_MAX_CHARS:
            selected.append(sentence)
            continue
        if not selected:
            selected.append(sentence[:SUMMARY_MAX_CHARS].rsplit(" ", 1)[0].rstrip(" ,.;:") + "...")
        break
    return " ".join(selected) or text


def medievalize_summary(summary: str) -> str:
    text = summary
    for pattern, replacement in ARCHAIC_REPLACEMENTS:
        text = re.sub(pattern, replacement, text, flags=re.IGNORECASE)
    ending = "" if text.endswith((".", "!", "?", "...")) else "."
    return f"Udite, udite, o genti del borgo: {text}{ending} Cosi' narrano gli scribi del Televideo."


def medieval_latin_summary(summary: str, translator: str, timeout: float, retries: int, cache: dict[str, str]) -> str:
    if translator == "local":
        return medievalize_summary(summary)
    try:
        latin = translate_latin_or_fallback(summary, translator, timeout, retries, cache, allow_local=False)
    except RuntimeError:
        return medievalize_summary(summary)
    if latin.count('"') % 2:
        latin += '"'
    ending = "" if re.search(r"(\.\.\.|[.!?])[\"'»”)]*$", latin) else "."
    return f"In chronicis scriptum est: {latin}{ending} Haec rettulerunt cursores Televidei."


def translator_label(translator: str) -> str:
    if translator == "auto":
        return "Google Translate gratuito non ufficiale; subsidia: MyMemory/localis"
    if translator == "google":
        return "Google Translate gratuito non ufficiale"
    if translator == "mymemory":
        return "MyMemory it|la"
    return "localis, sine rete"


def current_timestamp() -> str:
    return time.strftime("%Y-%m-%d %H:%M:%S %Z", time.localtime()).strip()


def format_medieval_summary(limit: int, search: str | None, show_url: bool, timeout: float, retries: int, translator: str) -> str:
    source, url = fetch_text(build_rss_urls(), timeout, retries)
    items, metadata = parse_news_feed(source)
    if search:
        needle = search.casefold()
        items = [item for item in items if needle in (item["title"] + " " + item["description"]).casefold()]

    items = items[:limit]
    feed_title = metadata.get("title") or "Rai Televideo Ultim'Ora"
    feed_update = metadata.get("pub_date") or metadata.get("last_build_date")
    lines = [
        "Chronica Televidei",
        "Notitiae verae ac recentissimae ex Rai Televideo",
        f"Fons: {feed_title} RSS 101",
        f"Captum: {current_timestamp()}",
    ]
    if feed_update:
        lines.append(f"Ultima renovatio fontis: {feed_update}")
    lines.append(f"Interpres: {translator_label(translator)}, cum colore chronicae mediaevalis")
    if search:
        lines.append(f"Quaestio: {search}")
    if show_url:
        lines.append(url)
    lines.append("")

    if not items:
        lines.append("Nulla novella inventa est.")
        return "\n".join(lines)

    translation_cache: dict[str, str] = {}
    for index, item in enumerate(items, start=1):
        italian_summary = summarize_description(item["description"])
        latin_title = translate_latin_title(item["title"], translator, timeout, retries, translation_cache)
        summary = medieval_latin_summary(italian_summary, translator, timeout, retries, translation_cache)
        lines.append(f"Capitulum {roman_number(index)} - {latin_title}")
        lines.append(f"Titulus fontis: {item['title']}")
        if item["pub_date"]:
            lines.append(f"Tempus fontis: {item['pub_date']}")
        if show_url and item["link"]:
            lines.append(f"Vinculum: {item['link']}")
        lines.extend(textwrap.wrap(summary, width=78))
        lines.append("")

    return "\n".join(lines).rstrip()


def emit(output: str, output_path: str | None) -> int:
    print(output)
    if output_path:
        with open(output_path, "w", encoding="utf-8") as file:
            file.write(output.rstrip() + "\n")
    return 0


def print_image_page(page: str, region: str, show_url: bool, timeout: float, retries: int) -> int:
    urls = build_image_urls(page, region)

    renderer = shutil.which("chafa")
    if not renderer:
        print("Renderer immagini non trovato. Installa 'chafa' oppure apri questo URL:")
        print(urls[0])
        return 0

    suffix = f"-televideo-{page}.png"
    with tempfile.NamedTemporaryFile(suffix=suffix) as tmp:
        data, url = fetch_bytes(urls, timeout, retries)
        if show_url:
            print(url, flush=True)
        tmp.write(data)
        tmp.flush()
        subprocess.run([renderer, tmp.name], check=False)
    return 0


def format_selected_output(args: argparse.Namespace, region: str) -> str:
    if args.medieval_summary is not None:
        return format_medieval_summary(args.medieval_summary, args.search, args.url, args.timeout, args.retries, args.latin_translator)
    if args.news is not None:
        return format_news(args.news, args.full, args.search, args.url, args.timeout, args.retries)
    if args.capture:
        return format_capture_page(args.page, region, args.url, args.timeout, args.retries)
    return format_text_page(args.page, args.subpage, region, args.url, args.timeout, args.retries)


def watch_output(args: argparse.Namespace, region: str) -> int:
    count = args.count
    iteration = 0
    while count is None or iteration < count:
        iteration += 1
        output = format_selected_output(args, region)
        print("\033[2J\033[H", end="")
        print(output)
        if args.output:
            with open(args.output, "w", encoding="utf-8") as file:
                file.write(output.rstrip() + "\n")
        if count is not None and iteration >= count:
            break
        time.sleep(args.watch)
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Legge le Ultim'Ora Rai Televideo e le rende come cronaca medievale.",
        epilog=(
            "Esempi: televideo | televideo --search Papa | televideo --medievale 8 | "
            "televideo --news 5 --full | televideo 100 | televideo 100 --image"
        ),
    )
    parser.add_argument("page", nargs="?", type=validate_page, help="pagina Televideo da consultare, es. 100")
    parser.add_argument("-s", "--subpage", type=validate_subpage, help="sottopagina, es. 1")
    parser.add_argument("-r", "--region", help="regione Rai, es. Lazio, Lombardia, Emilia-Romagna")
    parser.add_argument("--image", action="store_true", help="mostra la pagina grafica con chafa, se installato")
    parser.add_argument("--capture", action="store_true", help="cattura tutte le sottopagine disponibili della pagina")
    parser.add_argument("--news", nargs="?", const=DEFAULT_NEWS_LIMIT, type=positive_int, help="mostra le ultime N notizie RSS in formato originale, default 10")
    parser.add_argument(
        "--medieval-summary",
        "--medievale",
        nargs="?",
        const=DEFAULT_MEDIEVAL_LIMIT,
        type=positive_int,
        dest="medieval_summary",
        help="traduce e riassume le ultime N notizie live in latino medievaleggiante, default 5",
    )
    parser.add_argument(
        "--latin-translator",
        choices=("auto", "google", "mymemory", "local"),
        default="auto",
        help="traduttore per --medieval-summary: auto, google, mymemory o local, default auto",
    )
    parser.add_argument("--full", action="store_true", help="con --news, mostra anche il testo completo delle notizie")
    parser.add_argument("--search", help="cerca nel feed Ultim'Ora; se usato da solo filtra la cronaca medievale")
    parser.add_argument("--watch", type=positive_float, help="aggiorna l'output ogni N secondi")
    parser.add_argument("--count", type=positive_int, help="numero di aggiornamenti da fare con --watch")
    parser.add_argument("-o", "--output", help="salva l'output testuale in un file")
    parser.add_argument("--url", action="store_true", help="stampa anche l'URL sorgente")
    parser.add_argument("--timeout", type=positive_float, default=DEFAULT_TIMEOUT, help="timeout per host in secondi, default 10")
    parser.add_argument("--retries", type=non_negative_int, default=DEFAULT_RETRIES, help="ritentativi dopo il primo giro, default 1")
    return parser


def main(argv: list[str] | None = None) -> int:
    argv = list(sys.argv[1:] if argv is None else argv)

    parser = build_parser()
    args = parser.parse_args(argv)
    region = normalize_region(args.region)
    explicit_page = args.page is not None

    if args.search and args.news is None and args.medieval_summary is None:
        args.medieval_summary = DEFAULT_MEDIEVAL_LIMIT
    if not explicit_page and args.news is None and args.medieval_summary is None and not args.image and not args.capture:
        args.medieval_summary = DEFAULT_MEDIEVAL_LIMIT
    if args.page is None:
        args.page = DEFAULT_PAGE

    selected_modes = sum(1 for selected in (args.image, args.capture, args.news is not None, args.medieval_summary is not None) if selected)
    if selected_modes > 1:
        parser.error("usa solo una modalita tra --image, --capture, --news e --medieval-summary")
    if args.image and (args.output or args.watch):
        parser.error("--image non supporta --output o --watch")
    if args.count and not args.watch:
        parser.error("--count richiede --watch")

    try:
        if args.image:
            return print_image_page(args.page, region, args.url, args.timeout, args.retries)
        if args.watch:
            return watch_output(args, region)
        return emit(format_selected_output(args, region), args.output)
    except RuntimeError as exc:
        print(f"Errore: {exc}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
